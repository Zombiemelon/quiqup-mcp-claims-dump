# Clerk — fill in from Clerk dashboard or your secrets store
# (datacube uses CLERK_PUBLISHABLE_KEY (no prefix) because it's not a Next.js app;
#  we're a Next.js app so we use NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY which @clerk/nextjs requires)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# Backend SDK credential. Used for:
# 1. Inbound JWT verification (@clerk/nextjs's auth() in route.ts)
# 2. Outbound session-JWT minting (lib/quiqup.ts — V3b token translation:
#    exchanges the inbound at+jwt for a session-JWT-shaped token with the
#    "default" template, which is what Quiqup's API gateway accepts).
# This is the ONLY stored secret. No Quiqup-side partner credentials.
CLERK_SECRET_KEY=sk_live_...

# Issuer (custom domain) — used to derive AS metadata
CLERK_DOMAIN=clerk.quiqup.com

# Resource indicator — must match deployed URL exactly (RFC 8707)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Evals (evals/) only — not needed for the MCP server itself ---

# Langfuse — keys from Langfuse UI → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Anthropic — model under test in evals/
ANTHROPIC_API_KEY=sk-ant-...

# Quiqup staging — for the online round-trip eval only
# (eval:lastmile-roundtrip hits api.staging.quiqup.com directly via OAuth2
# client_credentials; NOT used by the MCP server itself, which uses Clerk).
# Must be a LAST-MILE-scoped client. Get one at qadmin.quiqup.com/oauth/clients.
QUIQUP_STAGING_CLIENT_ID=
QUIQUP_STAGING_CLIENT_SECRET=
# QUIQUP_LM_STAGING_BASE_URL=https://api.staging.quiqup.com   # override only if needed
