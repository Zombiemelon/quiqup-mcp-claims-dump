# Clerk — fill in from Clerk dashboard or your secrets store
# (datacube uses CLERK_PUBLISHABLE_KEY (no prefix) because it's not a Next.js app;
#  we're a Next.js app so we use NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY which @clerk/nextjs requires)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Issuer (custom domain) — used to derive AS metadata
CLERK_DOMAIN=clerk.quiqup.com

# Resource indicator — must match deployed URL exactly (RFC 8707)
NEXT_PUBLIC_APP_URL=http://localhost:3000
