# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# stagehand local browser profile (persists cookies between integration test runs)
.stagehand-userdata/

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — per-developer local settings (project-shared settings.json IS committed)
.claude/settings.local.json
# claude code — agent worktree isolation workspaces (local-only checkouts)
.claude/worktrees/

# python bytecode caches (from docs/quiqup-api/scripts/)
__pycache__/
*.pyc
