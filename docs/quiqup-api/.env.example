# Quiqup Fulfilment API credentials.
#
# Copy this file to `.env` in the same folder and fill in the values:
#   cp .env.example .env
#
# The wrapper (scripts/quiqup.sh) sources this file AFTER the repo-root .env,
# so values here override anything set at the repo root. `.env` is gitignored;
# do not commit real secrets.
#
# Default environment is staging. Production vars are only required if you run
# the wrapper with `--env prod`.

# ============================================================
# Fulfilment API (--api fulfilment — DEFAULT)
# Base: platform-api[.staging].quiqup.com
# ============================================================

# Staging
QUIQUP_CLIENT_ID=
QUIQUP_CLIENT_SECRET=

# Production (only needed for --env prod)
QUIQUP_PROD_CLIENT_ID=
QUIQUP_PROD_CLIENT_SECRET=

# ============================================================
# Last-Mile API (--api lastmile)
# Base: api[.staging].quiqup.com
# Different credentials from the Fulfilment API.
# ============================================================

# Staging
QUIQUP_LM_CLIENT_ID=
QUIQUP_LM_CLIENT_SECRET=

# Production
QUIQUP_LM_PROD_CLIENT_ID=
QUIQUP_LM_PROD_CLIENT_SECRET=
